<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="#F5F5F5">

    <TextView
        android:text="SympNet"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#009688"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Smart Medical Assistant"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginBottom="40dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Email icon -->
    <TextView
        android:text="✉"
        android:textSize="64sp"
        android:textColor="#009688"
        android:layout_marginBottom="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Verify your email"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tvEmail"
        android:textSize="14sp"
        android:textColor="#757575"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Please check your inbox and click the verification link before continuing."
        android:textSize="14sp"
        android:textColor="#757575"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnCheck"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="I've verified my email"
        android:textSize="16sp"
        android:backgroundTint="#009688"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnResend"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Resend verification email"
        android:textSize="16sp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#009688"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvBackToLogin"
        android:text="Back to Login"
        android:textColor="#009688"
        android:textSize="14sp"
        android:padding="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="#009688"
        android:layout_marginTop="16dp"/>

</LinearLayout>